{
  "name": "@platform/functions",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "lib/index.js",
  "scripts": {
    "build": "pnpm --filter @platform/web build && tsc && tsx scripts/copy-next-build.ts",
    "build:watch": "tsc --watch",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude '**/*.integration.test.ts'",
    "test:watch": "vitest",
    "test:integration": "vitest run integration",
    "test:emulator": "firebase emulators:exec --only firestore,auth 'vitest run integration'",
    "serve": "pnpm build && firebase emulators:start --only functions",
    "shell": "pnpm build && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@platform/shared": "workspace:*",
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^5.1.1",
    "jose": "^5.10.0",
    "next": "^14.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
