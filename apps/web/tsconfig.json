{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@shared/*": ["../../packages/shared/src/*"]
    },
    "allowJs": true,
    "exactOptionalPropertyTypes": false
  },
  "//": "exactOptionalPropertyTypes: false requerido por componentes generados por shadcn (DropdownMenu, Sonner). Mantener hasta migrar a shadcn CLI >= 2.x con tipos corregidos.",
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next", "dist"]
}
