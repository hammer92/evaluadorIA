rules_version = '2';

// =============================================================================
// Firestore Security Rules
// =============================================================================
// Decisiones de diseño:
//   - DENEGACIÓN POR DEFECTO: cualquier acceso no explícito falla
//   - Custom Claims son la única fuente de verdad para roles (ver ADR-0006)
//   - Strict createdAt: el cliente no puede falsificar fechas (Q2-A)
//   - Modelo de capacidades ortogonal por rol (no jerárquico)
// =============================================================================
// IMPORTANTE: el wrapper `match /databases/{database}/documents` es OBLIGATORIO.
// Sin él, las reglas no matchean requests del cliente SDK en el emulador
// (ni en producción con iOS/Android/JS SDK v9+). Validado con verify-rules.ts.
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {
    // DENEGACIÓN POR DEFECTO (cubre cualquier path no declarado explícitamente)
    match /{document=**} {
      allow read, write: if false;
    }

    // ============ USERS ============
    // Modelo de capacidades por rol: ver ADR-0006.
    //   admin     → superuser (puede todo)
    //   recruiter → gestiona candidatos (CRUD users OK, settings NO)
    //   expert    → edita technical tests (puede leer users, NO modificarlos)
    match /users/{uid} {
      // Lectura: el propio user, admin, recruiter (necesita ver candidatos que invites)
      // o expert (necesita ver otros para asignar a candidatos).
      // Ver SDD-03 spec sección 6.1.
      allow read: if isSignedIn() && (isSelf(uid) || hasAnyRole(['admin', 'recruiter', 'expert']));

      // Creación: admin o recruiter (ambos pueden invitar)
      allow create: if isSignedIn() && hasAnyRole(['admin', 'recruiter'])
        && request.resource.data.keys().hasAll(['email', 'role', 'status', 'createdAt'])
        && request.resource.data.role in ['admin', 'recruiter', 'expert']
        && request.resource.data.status in ['active', 'invited', 'suspended']
        && request.resource.data.createdAt == request.time;

      // Update: admin total, recruiter puede editar excepto cambiar role,
      //         user solo displayName/photoURL propios.
      // Defense in depth: el código (services) ya valida esto, pero las reglas
      // son la última línea.
      allow update: if isSignedIn() && (
        hasRole('admin')
        || (hasRole('recruiter') && onlyAffects(['displayName', 'photoURL', 'status']))
        || (isSelf(uid) && onlyAffects(['displayName', 'photoURL']))
      );

      // Delete (soft): solo admin
      allow delete: if isSignedIn() && hasRole('admin');

      // Listado: admin, recruiter (gestiona candidatos), expert (necesita ver otros para asignar)
      allow list: if isSignedIn() && hasAnyRole(['admin', 'recruiter', 'expert']);
    }

    // ============ ORGANIZATIONS ============
    match /organizations/{orgId} {
      // Lectura: miembros de la org (admin siempre)
      allow read: if isSignedIn() && isMemberOfOrg(orgId);

      // Settings/billing: solo admin (con strict createdAt al crear)
      allow create: if isSignedIn() && hasRole('admin')
        && request.resource.data.keys().hasAll(['name', 'slug', 'plan', 'createdAt'])
        && request.resource.data.plan in ['free', 'pro', 'enterprise']
        && request.resource.data.createdAt == request.time;
      allow update, delete: if isSignedIn() && hasRole('admin');

      // Subcollection memberships
      match /memberships/{membershipId} {
        allow read: if isSignedIn() && isMemberOfOrg(orgId);
        allow write: if isSignedIn() && hasAnyRole(['admin', 'recruiter']);
      }
    }

    // ============ AUDIT LOGS ============
    // Append-only. Lectura: admin (todas), recruiter/expert (filtrado a su org).
    // Escritura: SOLO desde Cloud Functions (Admin SDK bypassa reglas).
    match /auditLogs/{logId} {
      allow read: if isSignedIn() && (
        hasRole('admin')
        || (resource != null && resource.data.organizationId == request.auth.token.organizationId)
      );
      allow write: if false;
    }

    // ============ TEMPLATES (SDD-10 §9.1) ============
    // Multi-tenant: cada template pertenece a una organización. Filtrado por
    // organizationId del custom claim. Defense in depth con CFs (que ya
    // validan rol + estado en transition-template).
    // =====================================================================
    //   admin     → CRUD completo en su org
    //   expert    → READ cualquier estado; UPDATE solo si status='in_review'
    //               y solo campos técnicos (recipes)
    //   recruiter → READ solo si status='approved' y deleted_at==null
    // =====================================================================
    match /organizations/{orgId}/templates/{templateId} {
      // Lectura: defensa en profundidad (CF también re-valida via canViewTemplate).
      //   - admin y expert: cualquier template no-archivado de su org
      //   - recruiter: solo approved y no-archivado
      //   - deleted_at != null: solo admin
      allow read: if isSignedIn() && isMemberOfOrg(orgId) && (
        hasAnyRole(['admin', 'expert'])
        || (hasRole('recruiter')
            && resource.data.status == 'approved'
            && resource.data.deleted_at == null)
        || (resource.data.deleted_at != null && hasRole('admin'))
      );

      // List: misma lógica que read (Firestore evalúa por-doc).
      allow list: if isSignedIn() && isMemberOfOrg(orgId) && (
        hasAnyRole(['admin', 'expert'])
        || hasRole('recruiter')
      );

      // Crear: solo admin. Status inicial DEBE ser 'draft'.
      // El cliente NUNCA debería crear templates (es Cloud Function),
      // pero bloqueamos igual para defense in depth.
      allow create: if isSignedIn() && isMemberOfOrg(orgId) && hasRole('admin')
        && request.resource.data.status == 'draft'
        && request.resource.data.organization_id == orgId
        && request.resource.data.created_by == request.auth.uid;

      // Update: depende del rol y estado (state machine).
      //   - admin: solo si status in ['draft', 'changes_requested'],
      //     Y NO puede cambiar status via update directo (eso solo via
      //     Cloud Function para tener audit).
      //   - expert: solo si status='in_review', Y solo campos 'recipes' o
      //     'updated_at' (NO name/desc/niche/timeLimitMinutes/maxRetries).
      allow update: if isSignedIn() && isMemberOfOrg(orgId) && (
        (hasRole('admin')
          && (resource.data.status == 'draft' || resource.data.status == 'changes_requested')
          && resource.data.status == request.resource.data.status)
        || (hasRole('expert')
          && resource.data.status == 'in_review'
          && request.resource.data.status == 'in_review'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['recipes', 'updated_at']))
      );

      // Delete (soft): solo admin. Hard delete bloqueado (deleted_at only).
      allow delete: if isSignedIn() && isMemberOfOrg(orgId) && hasRole('admin');

      // Sub-colección de reviews: append-only desde Cloud Functions.
      match /reviews/{reviewId} {
        allow read: if isSignedIn() && isMemberOfOrg(orgId) && (
          hasAnyRole(['admin', 'expert'])
          || (hasRole('recruiter')
              && get(/databases/$(database)/documents/organizations/$(orgId)/templates/$(templateId)).data.status == 'approved')
        );
        // Escritura: NUNCA desde cliente. Solo Cloud Functions (Admin SDK bypassa).
        allow write: if false;
      }
    }

    // ============ Helpers ============
    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return request.auth.uid == uid;
    }
    function hasRole(role) {
      return request.auth.token.role == role;
    }
    function hasAnyRole(roles) {
      return request.auth.token.role in roles;
    }
    function isMemberOfOrg(orgId) {
      return request.auth.token.organizationId == orgId || hasRole('admin');
    }
    function onlyAffects(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }
  }
}