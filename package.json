{
  "name": "admin-platform",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:web": "bash scripts/dev.sh web",
    "dev:emulators": "bash scripts/dev.sh emulators",
    "build": "pnpm -r build",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run --exclude '**/*.integration.test.ts' --exclude '**/*.rules.spec.ts'",
    "test:watch": "vitest",
    "test:coverage": "vitest run --exclude '**/*.integration.test.ts' --exclude '**/*.rules.spec.ts' --coverage",
    "test:integration": "pnpm --filter @platform/functions test:integration",
    "test:rules": "pnpm --filter @platform/functions test:rules:emulator",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "emulators": "firebase emulators:start --project dev --import ./emulator-data --export-on-exit ./emulator-data",
    "emulators:detach": "bash scripts/emulators.sh start-detached",
    "emulators:stop": "bash scripts/emulators.sh stop",
    "emulators:status": "bash scripts/emulators.sh status",
    "emulators:logs": "bash scripts/emulators.sh logs",
    "emulators:reset": "rm -rf ./emulator-data && firebase emulators:start --project dev",
    "seed:emulators": "tsx scripts/seed-emulators.ts",
    "verify:auth": "tsx scripts/verify-auth.ts",
    "verify:rules": "tsx scripts/verify-rules.ts",
    "verify:lighthouse": "tsx scripts/verify-lighthouse.mts",
    "emulators:test": "pnpm --filter @platform/functions build && firebase emulators:exec --project admin-platform-dev --only firestore,auth,functions 'pnpm test:integration'",
    "emulators:rules": "pnpm --filter @platform/functions build && firebase emulators:exec --project admin-platform-dev --only firestore,auth,storage 'pnpm verify:rules'",
    "emulators:auth": "pnpm --filter @platform/functions build && firebase emulators:exec --project admin-platform-dev --only firestore,auth,functions 'pnpm verify:auth'",
    "deploy": "echo 'Deploy via .github/workflows/main_deploy.yml (push a main)' && exit 0",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.12.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^2.1.0",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "firebase-admin": "^12.6.0",
    "husky": "^9.1.0",
    "lighthouse": "^12.8.2",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.64.0",
    "vitest": "^2.1.0"
  }
}
