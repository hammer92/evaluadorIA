# =============================================================================
# .env — defaults compartidos para desarrollo local contra emuladores Firebase.
# =============================================================================
# Este archivo SE COMMITEa al repo (a diferencia de .env.local). Contiene los
# valores por defecto para que `pnpm emulators:detach` + `pnpm --filter @platform/web dev`
# arranquen sin requerir configuración adicional en una workstation nueva.
#
# Para overrides personales (puertos, project IDs distintos, secrets reales),
# copiá este archivo a `.env.local` y editá los valores allí. `.env.local`
# está en .gitignore y NO se commitea.
#
# En staging/prod, TODAS estas variables se setean vía Secret Manager o el
# runtime del deploy (NO usar este archivo fuera de dev).
# =============================================================================

# === Firebase Client (NEXT_PUBLIC_*) ===
NEXT_PUBLIC_FIREBASE_API_KEY=fake-api-key-for-emulator
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=admin-platform-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=admin-platform-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=admin-platform-dev.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# === App Config ===
NEXT_PUBLIC_APP_ENV=dev
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:5001/admin-platform-dev/us-central1

# === Server-side (NO exponer al cliente) ===
# El emulador de Auth tolera cualquier service account; no se usan en código
# de runtime contra emuladores (firebase-admin se inicializa con application
# default credentials cuando está disponible). Dejar vacíos acá.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# === Repository driver ===
# `memory` para tests/UI playground rápido; `firebase` para flujo completo
# contra emuladores (login, audit logs persistentes, etc.).
REPOSITORY_DRIVER=firebase

# === CORS ===
ALLOWED_ORIGINS=http://localhost:3000

# === Secrets (NO setear acá; usar apps/functions/.secret.local) ===
# RESEND_API_KEY=
# SESSION_COOKIE_SECRET se resuelve desde apps/functions/.secret.local
# (Firebase Functions emulator lo lee nativamente) y desde
# apps/web/lib/env-dev-defaults.ts en el lado Next.js (Edge + Node).
# Mismo valor en ambos lugares es REQUISITO para que el middleware pueda
# verificar la cookie firmada por la Cloud Function createSession.