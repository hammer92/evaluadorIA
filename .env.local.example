# =============================================================================
# .env.local.example — plantilla para overrides personales (NO commitear).
# =============================================================================
# Copiá este archivo a `.env.local` y editá los valores que necesites overridear.
# `.env.local` está cubierto por .gitignore. Next.js y firebase-functions lo
# cargan automáticamente y pisan los valores del .env base.
#
# Casos de uso típicos:
#   - Cambiar el project ID del emulador (multi-workstation).
#   - Apuntar a emuladores corriendo en otra máquina (NEXT_PUBLIC_API_BASE_URL).
#   - Activar REPOSITORY_DRIVER=memory para tests sin emuladores.
# =============================================================================

# === Override de Firebase project ===
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=admin-platform-dev
# FIREBASE_PROJECT=dev

# === Override de API base (otro host/puerto) ===
# NEXT_PUBLIC_API_BASE_URL=http://192.168.1.42:5001/admin-platform-dev/us-central1

# === Override de driver de repositorio ===
# REPOSITORY_DRIVER=memory

# === Override de CORS ===
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001